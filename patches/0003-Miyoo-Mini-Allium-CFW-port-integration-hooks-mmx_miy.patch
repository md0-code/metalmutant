@@ -1208,7 +1224,12 @@ FILE * sys_fopen(char * path, u16 mode) {
     }
 
     ALIS_DEBUG(EDebugInfo, " [%s][%.3x] ", path, mode);
+#ifdef ALIS_MIYOO_ALLIUM
+    // lowercasing the whole path breaks on case-sensitive /mnt/SDCARD
+    return fopen(miyoo_path_ci(path), flag);
+#else
     return fopen(strlower(path), flag);
+#endif
 }
 
