@@ -1180,7 +1183,12 @@ static void cload(void) {
         script_read_until_zero(name);
         strcpy(strrchr(name, '.') + 1, alis.platform.ext);
         strcat(path, name);
+#ifdef ALIS_MIYOO_ALLIUM
+        // keep the directory case; only the basename is matched on disk
+        script_load(miyoo_path_ci((char *)path));
+#else
