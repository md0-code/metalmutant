+// Draws the mmx OSD line (cheat/state messages) over the frame,
+// top-left, using the embedded 8x8 font.
+void mmx_osd_render(void)
+{
+    const char *text = mmx_osd_current();
+    if (text == NULL)
+        return;
+
+    int len = (int)strlen(text);
+    int win_w = 0, win_h = 0;
+    SDL_GetRendererOutputSize(renderer, &win_w, &win_h);   // physical pixels
+
+    // the game itself renders through a scaled renderer — draw the OSD in
+    // physical pixels instead, or the scale is applied twice
+    float game_sx = 1.0f, game_sy = 1.0f;
+    SDL_RenderGetScale(renderer, &game_sx, &game_sy);
+    SDL_RenderSetScale(renderer, 1.0f, 1.0f);
+
+    int px = win_h / 300;                 // ~16px text on a 600px window
+    if (px < 1) px = 1;
+    while (px > 1 && len * 8 * px > win_w - 16)
+        px--;                             // long line: shrink to fit
+    int margin = 4 * px;
+
+    SDL_SetRenderDrawBlendMode(renderer, SDL_BLENDMODE_BLEND);
+    SDL_SetRenderDrawColor(renderer, 0, 0, 0, 190);
+    SDL_Rect bg = { margin - 2 * px, margin - 2 * px,
+                    len * 8 * px + 4 * px, 8 * px + 4 * px };
+    SDL_RenderFillRect(renderer, &bg);
+
+    SDL_SetRenderDrawColor(renderer, 80, 255, 100, 255);   // HUD green
+    for (int i = 0; i < len; i++) {
+        unsigned char c = (unsigned char)text[i];
+        if (c < 32 || c > 126)
+            c = ' ';
+        const unsigned char *glyph = mmx_font8x8[c - 32];
+        for (int y = 0; y < 8; y++) {
+            for (int x = 0; x < 8; x++) {
+                if (glyph[y] & (1 << x)) {
+                    SDL_Rect dot = { margin + (i * 8 + x) * px, margin + y * px, px, px };
+                    SDL_RenderFillRect(renderer, &dot);
+                }
+            }
+        }
+    }
+    SDL_SetRenderDrawBlendMode(renderer, SDL_BLENDMODE_NONE);
+    SDL_RenderSetScale(renderer, game_sx, game_sy);
+}
