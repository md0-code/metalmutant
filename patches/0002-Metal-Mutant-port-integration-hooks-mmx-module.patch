+// Mirrors the load path in script.c (script_load): read magic + check,
+// set alis.typepack, then either depack via unpack_script() or strip the header.
+static void unpack_mode(const char *path) {
+
+    // note: platform.path arrives with a trailing separator (see pl_guess)
+    char outdir[kPathMaxLen * 2];
+    snprintf(outdir, sizeof(outdir), "%sunpacked", path);
+    ALIS_MKDIR(outdir);
+
+    DIR *dir = opendir(path);
+    if (dir == NULL) {
+        printf("Cannot open folder: %s\n", path);
+        return;
+    }
+
+    int done = 0, skipped = 0;
+    struct dirent *ent;
+    while ((ent = readdir(dir)) != NULL) {
+        const char *dot = strrchr(ent->d_name, '.');
+        if (dot == NULL || ALIS_STRCASECMP(dot + 1, alis.platform.ext) != 0)
+            continue;
+
+        char inpath[kPathMaxLen * 2];
+        snprintf(inpath, sizeof(inpath), "%s%s", path, ent->d_name);
+
+        FILE *fp = fopen(inpath, "rb");
+        if (fp == NULL)
+            continue;
+
+        fseek(fp, 0L, SEEK_END);
+        u32 input_sz = (u32)ftell(fp);
+        rewind(fp);
+
+        u32 magic = fread32(fp);
+        u16 check = fread16(fp);
+
+        alis.typepack = magic >> 24;
+        if (alis.platform.kind == EPlatformPC)
+            alis.typepack &= 0xfe;
+
+        u32 unpack_sz = magic & 0x00ffffff;
+        u8 *buf = (u8 *)malloc(1024 + unpack_sz);
+        memset(buf, 0, 1024 + unpack_sz);
+        s32 out_sz = 0;
+
+        if (alis.typepack < 0) {
+            fclose(fp);
+            out_sz = unpack_script(inpath, buf);
+        }
+        else {
+            s32 seekto = kPackedHeaderSize;
+            if (check == kMainScriptID)
+                seekto += kVMSpecsSize;
+
+            out_sz = (s32)unpack_sz - seekto;
+            if (out_sz > (s32)(input_sz - seekto))
+                out_sz = (s32)(input_sz - seekto);
+
+            if (out_sz > 0) {
+                fseek(fp, seekto, SEEK_SET);
+                fread(buf, sizeof(u8), out_sz, fp);
+            }
+            fclose(fp);
+        }
+
+        if (out_sz > 0) {
+            char outpath[kPathMaxLen * 2];
+            snprintf(outpath, sizeof(outpath), "%s%c%s", outdir, kPathSeparator, ent->d_name);
+            FILE *ofp = fopen(outpath, "wb");
+            if (ofp) {
+                fwrite(buf, sizeof(u8), out_sz, ofp);
+                fclose(ofp);
+                printf("  %-14s %8u -> %8d bytes%s\n", ent->d_name, input_sz, out_sz,
+                       alis.typepack < 0 ? "" : "  (not packed, header stripped)");
+                done++;
+            }
+        }
+        else {
+            printf("  %-14s SKIPPED (unpack failed: %d)\n", ent->d_name, out_sz);
+            skipped++;
+        }
+        free(buf);
+    }
+    closedir(dir);
+    printf("\nUnpacked %d file(s), %d skipped -> %s\n", done, skipped, outdir);
+}
